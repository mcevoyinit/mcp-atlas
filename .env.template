# MCP Catalog Configuration
# Copy to .env and fill in values

# DGraph connection (local Docker default)
DGRAPH_URL=http://localhost:18080

# DGraph ACL (leave blank if ACL disabled, as in local Docker)
DGRAPH_GROOT_PASSWORD=

# Smithery API key (get from smithery.ai/account/api-keys)
SMITHERY_API_KEY=

# GitHub token (optional, for higher rate limits)
GITHUB_TOKEN=
